# ============================================
# HEADSET INVENTORY SYSTEM - Environment Config
# ============================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8081
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=headset_inventory

# Session Configuration
SESSION_DURATION_MINUTES=30

# Upload Configuration
UPLOAD_ROOT=./uploads
MAX_FILE_SIZE_MB=5

# Allowed Network IP Ranges (comma-separated)
ALLOWED_IP_RANGES=192.168.10.0/24,192.168.7.0/24,192.168.9.0/24

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# PDF Configuration
COMPANY_NAME=Amii Business Support Solution Pvt Ltd.
COMPANY_ADDRESS=Tower No 4, 6th floor, 601, Railway Station Complex, CBD Belapur, Navi Mumbai, Maharashtra 400614
COMPANY_PHONE=+91 63547 98551
COMPANY_EMAIL=info@abss.co.in